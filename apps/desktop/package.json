{
  "name": "job-hunt-desktop",
  "productName": "Job Hunt",
  "version": "0.0.4",
  "description": "Job search desktop application powered by JSearch API",
  "author": "Luka Fagundes (https://github.com/lukadfagundes)",
  "private": true,
  "main": ".vite/build/index.js",
  "scripts": {
    "dev": "electron-forge start",
    "build": "electron-forge make",
    "build:win": "electron-forge make --platform win32",
    "build:mac": "electron-forge make --platform darwin",
    "build:linux": "electron-forge make --platform linux",
    "package": "electron-forge package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@job-hunt/core": "*",
    "docx": "^9.6.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.7.3",
    "jpeg-js": "^0.4.4",
    "konva": "^9.3.22",
    "mammoth": "^1.11.0",
    "pdf-parse": "^1.1.1",
    "pdfmake": "^0.3.5",
    "pngjs": "^7.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-konva": "^18.2.10"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron-forge/publisher-github": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
