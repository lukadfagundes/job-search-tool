{
  "name": "job-hunt-desktop",
  "version": "0.0.1",
  "description": "Job search desktop application powered by JSearch API",
  "author": "Luka Fagundes (https://github.com/lukadfagundes)",
  "private": true,
  "main": ".vite/build/index.js",
  "scripts": {
    "dev": "electron-forge start",
    "build": "electron-forge make",
